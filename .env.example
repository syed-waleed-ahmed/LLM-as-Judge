# Copy this file to `.env` and fill in your values. Never commit `.env`.

# Required: your Groq API key (https://console.groq.com/keys).
GROQ_API_KEY=your_groq_api_key_here

# Optional: which Groq-hosted model the judge uses.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional generation / request tuning.
JUDGE_TEMPERATURE=0.0
JUDGE_REQUEST_TIMEOUT=60
JUDGE_MAX_RETRIES=3

# Optional: run each comparison in both orders and average, to reduce the
# well-known position bias of LLM judges (doubles the number of API calls).
JUDGE_MITIGATE_POSITION_BIAS=false

# Optional: concurrency for `llm-judge batch`.
JUDGE_BATCH_MAX_WORKERS=4

# Optional: logging verbosity (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
